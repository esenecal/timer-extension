{
    "manifest_version": 3,
    "name": "timer-extension",
    "version": "0.1",

    "permissions": [
        "activeTab", 
        "scripting",
        "storage"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "timer-extension@text.com",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },

    "action": {
        "default_popup": "src/index.html"
    },

    "background": {
        "scripts": ["src/background.js"]
    }

}